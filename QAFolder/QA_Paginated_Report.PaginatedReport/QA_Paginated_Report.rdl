  <AutoRefresh>0</AutoRefresh>
  <DataSources>
    <DataSource Name="QA_Scorecard_CLI">
      <ConnectionProperties>
        <DataProvider>PBIDATASET</DataProvider>
        <ConnectString>Data Source=pbiazure://api.powerbi.com/;Identity Provider="https://login.microsoftonline.com/common, https://analysis.windows.net/powerbi/api, f0b72488-7082-488a-a7e8-eada97bd842d";Initial Catalog=sobe_wowvirtualserver-fdfabad8-7c6b-4bf1-8fcd-611e84a596ab;Integrated Security=ClaimsToken</ConnectString>
      </ConnectionProperties>
      <rd:SecurityType>None</rd:SecurityType>
    </DataSource>
  </DataSources>
  <DataSets>
    <DataSet Name="DataSet1">
      <Query>
        <DataSourceName>QA_Scorecard_CLI</DataSourceName>
        <CommandText>DEFINE VAR __DS0Core = 
	SELECTCOLUMNS(
		KEEPFILTERS(
			FILTER(
				KEEPFILTERS(
					SUMMARIZECOLUMNS(
						ROLLUPADDISSUBTOTAL(
							ROLLUPGROUP(
								'Goals'[Id],
								'Goals'[Name],
								'Goals'[Scorecard Id],
								'Goals'[Created time],
								'Goals'[Last modified time],
								'Goals'[Owner],
								'Goals'[Last modified by],
								'Goals'[Start date],
								'Goals'[Completion date],
								'Goals'[Parent id],
								'Goals'[Cycle],
								'Goals'[Cycle period],
								'Goals'[Values format string],
								'Goals'[Value timestamp],
								'Goals'[Value display string],
								'Goals'[Target display string],
								'Goals'[Status display name],
								'Goals'[Target timestamp],
								'Goals'[Status timestamp],
								'Notes'[Id],
								'Notes'[Value timestamp],
								'Notes'[Goal Id],
								'Notes'[Scorecard Id],
								'Notes'[Last modified time],
								'Notes'[Last modified by],
								'Notes'[Body],
								'Notes'[Created time],
								'Notes'[Value Id],
								'Scorecard'[Id],
								'Scorecard'[Name],
								'Scorecard'[Contact],
								'Scorecard'[Last modified by],
								'Scorecard'[Created time],
								'Scorecard'[Last modified time]
							), "IsGrandTotalRowTotal"
						),
						"SumValue", CALCULATE(SUM('Goals'[Value])),
						"SumTarget", CALCULATE(SUM('Goals'[Target])),
						"SumStatus", CALCULATE(SUM('Goals'[Status])),
						"HasDataNotes", IGNORE(
							CALCULATE(NOT(ISEMPTY('Notes')))
						)
					)
				),
				[HasDataNotes]
			)
		),
		"'Goals'[Id]", 'Goals'[Id],
		"'Goals'[Name]", 'Goals'[Name],
		"'Goals'[Scorecard Id]", 'Goals'[Scorecard Id],
		"'Goals'[Created time]", 'Goals'[Created time],
		"'Goals'[Last modified time]", 'Goals'[Last modified time],
		"'Goals'[Owner]", 'Goals'[Owner],
		"'Goals'[Last modified by]", 'Goals'[Last modified by],
		"'Goals'[Start date]", 'Goals'[Start date],
		"'Goals'[Completion date]", 'Goals'[Completion date],
		"'Goals'[Parent id]", 'Goals'[Parent id],
		"'Goals'[Cycle]", 'Goals'[Cycle],
		"'Goals'[Cycle period]", 'Goals'[Cycle period],
		"'Goals'[Values format string]", 'Goals'[Values format string],
		"'Goals'[Value timestamp]", 'Goals'[Value timestamp],
		"'Goals'[Value display string]", 'Goals'[Value display string],
		"'Goals'[Target display string]", 'Goals'[Target display string],
		"'Goals'[Status display name]", 'Goals'[Status display name],
		"'Goals'[Target timestamp]", 'Goals'[Target timestamp],
		"'Goals'[Status timestamp]", 'Goals'[Status timestamp],
		"'Notes'[Id]", 'Notes'[Id],
		"'Notes'[Value timestamp]", 'Notes'[Value timestamp],
		"'Notes'[Goal Id]", 'Notes'[Goal Id],
		"'Notes'[Scorecard Id]", 'Notes'[Scorecard Id],
		"'Notes'[Last modified time]", 'Notes'[Last modified time],
		"'Notes'[Last modified by]", 'Notes'[Last modified by],
		"'Notes'[Body]", 'Notes'[Body],
		"'Notes'[Created time]", 'Notes'[Created time],
		"'Notes'[Value Id]", 'Notes'[Value Id],
		"'Scorecard'[Id]", 'Scorecard'[Id],
		"'Scorecard'[Name]", 'Scorecard'[Name],
		"'Scorecard'[Contact]", 'Scorecard'[Contact],
		"'Scorecard'[Last modified by]", 'Scorecard'[Last modified by],
		"'Scorecard'[Created time]", 'Scorecard'[Created time],
		"'Scorecard'[Last modified time]", 'Scorecard'[Last modified time],
		"IsGrandTotalRowTotal", [IsGrandTotalRowTotal],
		"SumValue", [SumValue],
		"SumTarget", [SumTarget],
		"SumStatus", [SumStatus]
	)

EVALUATE
	__DS0Core

ORDER BY
	[IsGrandTotalRowTotal] DESC,
	'Goals'[Id],
	'Goals'[Name],
	'Goals'[Scorecard Id],
	'Goals'[Created time],
	'Goals'[Last modified time],
	'Goals'[Owner],
	'Goals'[Last modified by],
	'Goals'[Start date],
	'Goals'[Completion date],
	'Goals'[Parent id],
	'Goals'[Cycle],
	'Goals'[Cycle period],
	'Goals'[Values format string],
	'Goals'[Value timestamp],
	'Goals'[Value display string],
	'Goals'[Target display string],
	'Goals'[Status display name],
	'Goals'[Target timestamp],
	'Goals'[Status timestamp],
	'Notes'[Id],
	'Notes'[Value timestamp],
	'Notes'[Goal Id],
	'Notes'[Scorecard Id],
	'Notes'[Last modified time],
	'Notes'[Last modified by],
	'Notes'[Body],
	'Notes'[Created time],
	'Notes'[Value Id],
	'Scorecard'[Id],
	'Scorecard'[Name],
	'Scorecard'[Contact],
	'Scorecard'[Last modified by],
	'Scorecard'[Created time],
	'Scorecard'[Last modified time]</CommandText>
